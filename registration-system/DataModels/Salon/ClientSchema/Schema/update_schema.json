{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Client Update",
  "description": "Schema for updating a client object",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "description": "Action that modified the record",
      "enum": ["UPDATE-CLIENT"]
    },
    "updatedFields": {
      "type": "object",
      "description": "Fields that are being updated with their new values",
      "properties": {
        "ownerName": {
          "type": "string",
          "minLength": 1
        },
        "mobile": {
          "type": "string",
          "pattern": "^[0-9]{10,15}$"
        },
        "email": {
          "type": ["string", "null"],
          "format": "email"
        },
        "ownerAddress": {
          "type": "string"
        },
        "salonName": {
          "type": "string",
          "minLength": 1
        },
        "salonAddress": {
          "type": "string"
        },
        "serviceType": {
          "type": "string",
          "enum": ["Salon", "Beauty", "Hair", "Unisex", "Spa", "Combined"]
        },
        "workingHours": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": {
                "type": "string",
                "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
              },
              "openTime": {
                "type": "string",
                "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$"
              },
              "closeTime": {
                "type": "string",
                "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$"
              },
              "isClosed": {
                "type": "boolean",
                "default": false
              }
            },
            "required": ["day", "openTime", "closeTime"]
          }
        },
        "weeklyHoliday": {
          "type": "string"
        },
        "location": {
          "type": "object",
          "properties": {
            "latitude": {"type": "number"},
            "longitude": {"type": "number"}
          },
          "required": ["latitude", "longitude"]
        },
        "isOpen": {
          "type": "boolean"
        },
        "slots": {
          "type": "object",
          "patternProperties": {
            "^slot[0-9]+$": {
              "type": "object",
              "properties": {
                "slotTime": {
                  "type": "string"
                },
                "isAvailable": {
                  "type": "boolean"
                },
                "askBeforeBooking": {
                  "type": "boolean"
                }
              },
              "required": ["slotTime", "isAvailable", "askBeforeBooking"]
            }
          },
          "additionalProperties": false
        },
        "licence": {
          "type": ["string", "null"]
        },
        "approvalStatus": {
          "type": ["string", "null"],
          "enum": ["PENDING", "APPROVED", "REJECTED", null]
        },
        "business": {
          "type": "string",
          "minLength": 1,
          "description": "Business name or category"
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    }
  },
  "required": ["action", "updatedFields"],
  "additionalProperties": false
}
