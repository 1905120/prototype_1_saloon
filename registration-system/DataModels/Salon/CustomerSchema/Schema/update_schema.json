{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Customer Update",
  "description": "Schema for updating a customer object",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "description": "Action that modified the record",
      "enum": ["UPDATE-CUSTOMER"]
    },
    "updatedFields": {
      "type": "object",
      "description": "Fields that are being updated with their new values",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": ["string", "null"],
          "format": "email"
        },
        "phone": {
          "type": "string",
          "pattern": "^[0-9]{10,15}$"
        },
        "dateOfBirth": {
          "type": ["string", "null"],
          "format": "date"
        },
        "address": {
          "type": ["object", "null"],
          "properties": {
            "street": {"type": "string"},
            "city": {"type": "string"},
            "state": {"type": "string"},
            "country": {"type": "string"},
            "postalCode": {"type": "string"}
          }
        },
        "location": {
          "type": ["object", "null"],
          "properties": {
            "latitude": {"type": "number"},
            "longitude": {"type": "number"}
          },
          "required": ["latitude", "longitude"]
        },
        "approvalStatus": {
          "type": ["string", "null"],
          "enum": ["PENDING", "APPROVED", "MISSING-MANDATORY-FIELDS", null]
        },
        "business": {
          "type": "string",
          "minLength": 1,
          "description": "Business name or category"
        }
      },
      "additionalProperties": false,
      "minProperties": 1,
      "allOf": [
        {
          "if": {
            "required": ["name"]
          },
          "then": {
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "required": ["phone"]
          },
          "then": {
            "properties": {
              "phone": {
                "type": "string",
                "pattern": "^[0-9]{10,15}$"
              }
            }
          }
        }
      ]
    }
  },
  "required": ["updatedFields"],
  "additionalProperties": false
}
